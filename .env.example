# =============================================================================
# SWEET-CAKE — Variables d'environnement
# =============================================================================
# Copier ce fichier vers .env et adapter les valeurs

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# --- Base de donnees MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=sweet_cake_db
MYSQL_ROOT_PASSWORD=root_password_dev
DATABASE_URL="mysql://root:@localhost:3306/sweet_cake_db"

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=votre-secret-jwt-a-changer-en-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=votre-secret-refresh-a-changer-en-production
JWT_REFRESH_EXPIRATION=7d

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8100

# --- Rate Limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Mot de passe ---
BCRYPT_SALT_ROUNDS=12

# --- Langue par defaut ---
LANGUE_PAR_DEFAUT=fr

# --- Swagger ---
SWAGGER_TITRE=Sweet-Cake API
SWAGGER_DESCRIPTION=API de la plateforme de patisserie Sweet-Cake
SWAGGER_VERSION=1.0
SWAGGER_CHEMIN=api/docs
